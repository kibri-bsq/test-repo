      "aggregation": "sum",
      "formatHint": "currency"
    },
    "Cost": {
      "id": "Cost",
      "label": "Cost",
      "aggregation": "sum",
      "formatHint": "currency"
    },
    "Units": {
      "id": "Units",
      "label": "Units",
      "aggregation": "sum",
      "formatHint": "integer"
    },
    "Discount": {
      "id": "Discount",
      "label": "Discount",
