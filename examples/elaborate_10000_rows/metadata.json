      "formatHint": "currency"
    }
  },
  "kpis": {
    "GrossMargin": {
      "id": "GrossMargin",
      "label": "Gross Margin",
      "formula": "Revenue - Cost",
      "formulaType": "measure_based",
      "dependencies": [],
      "requiredDimensions": [],
      "totalStrategy": "recompute",
      "validAtLeaf": true,
      "validAtSubtotal": true,
      "validAtGrandTotal": true,
      "missingValueBehavior": "null",
      "formatHint": "currency",
      "version": "1"
    },
    "MarginPct": {
      "id": "MarginPct",
      "label": "Margin %",
      "formula": "GrossMargin / Revenue",
      "formulaType": "measure_based",
      "dependencies": [
        "GrossMargin"
      ],
      "requiredDimensions": [],
      "totalStrategy": "recompute",
      "validAtLeaf": true,
      "validAtSubtotal": true,
      "validAtGrandTotal": true,
      "missingValueBehavior": "warning",
      "formatHint": "percent",
      "version": "1"
    },
    "BudgetVariance": {
      "id": "BudgetVariance",
      "label": "Budget Variance",
      "formula": "Revenue[Scenario=Actual] - Revenue[Scenario=Budget]",
      "formulaType": "cross_member",
      "dependencies": [],
      "requiredDimensions": [
        "Scenario"
      ],
      "totalStrategy": "recompute",
      "validAtLeaf": true,
      "validAtSubtotal": true,
      "validAtGrandTotal": true,
      "missingValueBehavior": "warning",
      "formatHint": "currency",
      "version": "1"
    },
    "BudgetVariancePct": {
      "id": "BudgetVariancePct",
      "label": "Budget Variance %",
      "formula": "BudgetVariance / Revenue[Scenario=Budget]",
      "formulaType": "cross_member",
      "dependencies": [
        "BudgetVariance"
      ],
      "requiredDimensions": [
        "Scenario"
      ],
      "totalStrategy": "recompute",
      "validAtLeaf": true,
      "validAtSubtotal": true,
      "validAtGrandTotal": true,
      "missingValueBehavior": "warning",
      "formatHint": "percent",
      "version": "1"
    },
    "ContributionToParent": {
      "id": "ContributionToParent",
      "label": "Contribution To Parent",
      "formula": "Revenue / Revenue[Region=parent]",
      "formulaType": "context_relative",
      "dependencies": [],
      "requiredDimensions": [
        "Region"
      ],
      "totalStrategy": "recompute",
      "validAtLeaf": true,
      "validAtSubtotal": true,
      "validAtGrandTotal": false,
      "missingValueBehavior": "warning",
      "formatHint": "percent",
      "version": "1"
    },
    "MoMGrowth": {
      "id": "MoMGrowth",
      "label": "Month-over-Month Growth",
      "formula": "(Revenue - Revenue[Month=previous]) / Revenue[Month=previous]",
      "formulaType": "time_relative",
      "dependencies": [],
      "requiredDimensions": [
        "Month"
      ],
      "totalStrategy": "recompute",
      "validAtLeaf": true,
      "validAtSubtotal": true,
      "validAtGrandTotal": false,
      "missingValueBehavior": "warning",
      "formatHint": "percent",
      "version": "1"
    }
  }
